# Kedro
conf/local/**
!conf/local/.gitkeep
conf/**/*credentials*
.telemetry
.viz

# Data — ignore generated/intermediate files, keep raw inputs
data/**
!data/**/
!.gitkeep
# Raw input CSVs and schema are synthesised, small, and required at build time
!data/01_raw/*.csv
!data/01_raw/*.sql

# Logs
*.log

# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
build/
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Testing & coverage
.coverage
.coverage.*
htmlcov/
.cache
.tox/
coverage.xml

# Jupyter
.ipynb_checkpoints/

# macOS
.DS_Store
.AppleDouble
.Trashes

# IDEs
.idea/
.vscode/
*.iml

# Secrets
.env
.envrc

# mypy
.mypy_cache/
